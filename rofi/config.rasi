configuration {
    modi: "drun,run,window";
    show-icons: true;
    icon-theme: "Papirus";
    display-drun: "Apps";
    display-run: "Run";
    display-window: "Windows";
    drun-display-format: "{name}";
    disable-history: false;
    sidebar-mode: false;
    terminal: "alacritty";
}

@theme "~/.i3rc/rofi/launcher.rasi"
